#!/bin/sh
authority=operator
while [ "$#" -gt 0 ]; do
  case "$1" in
    --authority)
      authority="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done
if [ "$#" -eq 0 ]; then
  echo "Usage: cogos-law [--authority MODE] <action> [capability ...]"
  exit 2
fi
action="$1"
shift
args=""
for cap in "$@"; do
  args="$args --capability $cap"
done
exec python3 /opt/cogos/bin/cogos_daemon.py --authority "$authority" --evaluate "$action" $args
