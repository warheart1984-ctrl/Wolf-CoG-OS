#!/bin/sh
authority=operator
while [ "$#" -gt 0 ]; do
  case "$1" in
    --authority)
      authority="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done
if [ "$#" -eq 0 ]; then
  echo "Usage: cogos-run [--authority operator|developer|verifier|restricted-runtime] <task text>"
  exit 2
fi
exec python3 /opt/cogos/bin/cogos_daemon.py --authority "$authority" --run "$*"
