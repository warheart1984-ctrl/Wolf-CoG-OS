#!/bin/sh
authority=developer
while [ "$#" -gt 0 ]; do
  case "$1" in
    --authority)
      authority="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done
if [ "$#" -ne 1 ]; then
  echo "Usage: cogos-admit [--authority developer|verifier] <module-path>"
  exit 2
fi
exec python3 /opt/cogos/bin/cogos_daemon.py --authority "$authority" --admit "$1"
