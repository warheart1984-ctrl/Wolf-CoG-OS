{
  "name": "Project Infi / ARIS Cognitive OS Runtime",
  "version": "0.12",
  "root": "/opt/cogos",
  "paths": {
    "runtime": "/opt/cogos/runtime",
    "law": "/opt/cogos/law",
    "modules": "/opt/cogos/modules",
    "memory": "/opt/cogos/memory",
    "logs": "/opt/cogos/memory/logs",
    "tasks": "/opt/cogos/tasks",
    "traces": "/opt/cogos/memory/traces",
    "events": "/opt/cogos/memory/events"
  },
  "ul_runtime": {
    "path": "/opt/cogos/runtime/ul",
    "runs": "/opt/cogos/memory/ul/runs.jsonl",
    "substrate_audit": "/opt/cogos/memory/ul/substrate_audit.jsonl",
    "examples": "/opt/cogos/examples/ul"
  },
  "voss_runtime": {
    "path": "/opt/cogos/runtime/voss",
    "rep_traces": "/opt/cogos/memory/voss/rep_traces.jsonl",
    "verifications": "/opt/cogos/memory/voss/verifications.jsonl",
    "bindings": "/opt/cogos/memory/voss/bindings.jsonl",
    "proof": "/opt/cogos/memory/voss/proof.jsonl"
  },
  "boot": {
    "entrypoint": "/opt/cogos/bin/cognitive_init",
    "mode": "pid1_gatekeeper",
    "native_handoff": "/usr/sbin/init.original",
    "pid1_proof": "/opt/cogos/memory/logs/pid1_proof.json",
    "shell": "/opt/cogos/bin/cogos_shell",
    "report": "/opt/cogos/memory/logs/boot_report.json",
    "profile": "/opt/cogos/config/boot_profile.json"
  },
  "daemon": {
    "entrypoint": "/opt/cogos/bin/cogos_daemon.py",
    "pid": "/run/cogos-daemon.pid",
    "state": "/run/cogos-daemon.json",
    "task_inbox": "/opt/cogos/tasks/inbox",
    "trace": "/opt/cogos/memory/traces/aris_cycles.jsonl"
  },
  "law_engine": {
    "rules": "/opt/cogos/law/governance_rules.json",
    "decisions": "/opt/cogos/memory/traces/law_decisions.jsonl",
    "authority_modes": [
      "operator",
      "developer",
      "verifier",
      "restricted-runtime"
    ]
  },
  "snapshot": {
    "path": "/opt/cogos/memory/snapshots"
  },
  "reflection": {
    "queue": "/opt/cogos/memory/reflection/queue.jsonl"
  },
  "dashboard": {
    "bind": "127.0.0.1",
    "port": 8080,
    "url": "http://localhost:8080",
    "autostart": false
  },
  "verification": {
    "trace_verifications": "/opt/cogos/memory/traces/verifications.jsonl",
    "law_integrity": "/opt/cogos/memory/traces/law_integrity.jsonl"
  },
  "modules": {
    "local": "/opt/cogos/modules/local",
    "registry": "/opt/cogos/modules/registry.json",
    "trait_ledger": "/opt/cogos/memory/modules/trait_ledger.jsonl"
  },
  "sandbox": {
    "timeout_seconds": 5,
    "max_stdout_bytes": 65536,
    "max_stderr_bytes": 65536,
    "network": "denied",
    "write_paths": [],
    "capability_paths": {
      "trace.read": [
        "/opt/cogos/memory/traces"
      ],
      "memory.read": [
        "/opt/cogos/memory"
      ],
      "memory.append": [
        "/opt/cogos/memory/modules/executions.jsonl"
      ]
    }
  },
  "trait_runtime": {
    "mode": "observe_then_enforce",
    "drift_quarantine_threshold": 3,
    "high_severity_quarantine": true,
    "rules": {
      "readonly": {
        "forbids": [
          "memory.write",
          "network.write",
          "self.modify",
          "module.admit"
        ]
      },
      "non_mutating": {
        "forbids": [
          "memory.write",
          "network.write",
          "self.modify",
          "module.admit"
        ],
        "mutation_output_markers": [
          "mutate",
          "write",
          "delete",
          "self_modify"
        ]
      },
      "analytical": {
        "expects_structured_output": true
      },
      "verifier": {
        "expects_any_output_fields": [
          "proof",
          "checks",
          "verified",
          "trace_count"
        ]
      },
      "operator_tool": {
        "allowed_authority_modes": [
          "operator",
          "developer"
        ]
      }
    }
  },
  "pattern_ledger": {
    "path": "/opt/cogos/memory/patterns",
    "recurrence_threshold": 3,
    "auto_quarantine_severities": [
      "S4",
      "S5"
    ],
    "unknown_source_classification": "pending_review",
    "approved_sources": [
      "module_execution",
      "sandbox_denial",
      "law_denial",
      "trait_drift",
      "proof",
      "trace_verification",
      "operator_note"
    ]
  },
  "operator_handbook": {
    "path": "/opt/cogos/docs/OPERATOR_HANDBOOK.md"
  },
  "phase3": {
    "compute_tiers": "/opt/cogos/config/compute_tiers.json",
    "package_catalog": "/opt/cogos/config/package_catalog.json",
    "release_manifest": "/opt/cogos/config/release_manifest.json",
    "eval_report": "/opt/cogos/memory/logs/eval_report.json",
    "backups_root": "/opt/cogos/memory/backups"
  },
  "phase2": {
    "creative_root": "/opt/cogos/memory/creative",
    "mesh_root": "/opt/cogos/memory/mesh",
    "mesh_config": "/opt/cogos/config/mesh.json",
    "creative_entry": "/opt/cogos/bin/cogos_creative.py",
    "mesh_entry": "/opt/cogos/bin/cogos_mesh.py"
  },
  "phase1": {
    "desktop_port": 8081,
    "desktop_entry": "/opt/cogos/bin/cogos_desktop.py",
    "hal_entry": "/opt/cogos/bin/cogos_hal.py",
    "update_entry": "/opt/cogos/bin/cogos_update.py",
    "users_config": "/opt/cogos/config/users.json",
    "hal_snapshot": "/opt/cogos/memory/logs/hal_snapshot.json",
    "determinism_corridor": "/opt/cogos/memory/logs/determinism_corridor.json"
  }
}
