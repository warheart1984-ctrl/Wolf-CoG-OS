      "required_tier": "standard",
      "capabilities": ["trace.read", "module.execute"],
      "description": "Governed trace inspection tool"
    },
    {
      "id": "hello_ul",
      "name": "UL Hello Example",
      "version": "1.0.0",
      "artifact": "/opt/cogos/examples/ul/hello.ul",
