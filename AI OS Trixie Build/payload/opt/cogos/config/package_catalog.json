      "capabilities": ["ul.trace"],
      "description": "Reference UL trace example"
    },
    {
      "id": "operator_notes",
      "name": "Operator Notes",
      "version": "1.0.0",
      "install_type": "memory_slot",
      "memory_path": "/opt/cogos/memory/operator/notes",
      "required_tier": "standard",
      "capabilities": ["memory.append"],
      "description": "Local operator notes slot"
    },
    {
      "id": "ul_ecosystem_meta",
      "name": "UL Ecosystem Meta",
      "version": "1.0.0",
      "install_type": "memory_slot",
      "memory_path": "/opt/cogos/memory/packages/ul",
      "required_tier": "elevated",
      "capabilities": ["ul.pkg.install"],
      "description": "Slot for third-party UL packages (see cogos-ul-pkg)"
